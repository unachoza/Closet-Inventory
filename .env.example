# Copy to .env and fill in real values. .env is gitignored — never commit it.

# Client-side (VITE_ prefix = bundled into the browser; must be safe to expose publicly)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GOOGLE_CLIENT_ID=

# Server-side only (NO VITE_ prefix — bundling these into client JS would leak them)
SUPABASE_SECRET_KEY=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
