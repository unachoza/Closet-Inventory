# Environment setup — two files, never committed:
#
#   .env        → PRODUCTION (Vercel + prod Supabase project rawuntspvetfdtrqggen)
#                 Keep these values pointing at prod at all times.
#
#   .env.local  → LOCAL DEV (dev Supabase project, overrides .env during `npm run dev`)
#                 Create this file with your dev project's keys after running:
#                 `supabase link --project-ref <dev-project-ref>`
#
# Vite automatically merges .env.local over .env locally — no code changes needed.
# Vercel never reads .env or .env.local — configure env vars in the Vercel dashboard.

# Client-side (VITE_ prefix = bundled into the browser; must be safe to expose publicly)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GOOGLE_CLIENT_ID=

# Server-side only (NO VITE_ prefix — bundling these into client JS would leak them)
SUPABASE_SECRET_KEY=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
