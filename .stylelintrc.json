{
  "plugins": ["stylelint-order"],
  "rules": {
    "order/order": [
      [
        { "type": "at-rule", "name": "import" },
        "declarations",
        "rules",
        { "type": "at-rule", "name": "media" }
      ],
      { "severity": "warning" }
    ],
    "order/properties-order": [
      [
        {
          "groupName": "Positioning",
          "properties": ["position", "top", "right", "bottom", "left", "z-index"]
        },
        {
          "groupName": "Display & Box Model",
          "properties": [
            "display", "flex-direction", "justify-content", "align-items", "align-content", "flex-wrap", "float", "clear", "overflow", "box-sizing",
            "width", "height", "max-width", "max-height", "min-width", "min-height",
            "margin", "padding", "border", "border-radius"
          ]
        },
        {
          "groupName": "Visual",
          "properties": ["background", "background-color", "background-image", "box-shadow", "color", "opacity"]
        },
        {
          "groupName": "Typography",
          "properties": [
            "font-family", "font-size", "font-weight", "line-height", "text-align",
            "text-decoration", "text-transform", "letter-spacing"
          ]
        },
        {
          "groupName": "Other",
          "properties": ["cursor", "transition", "transform", "animation"]
        }
      ],
      { "unspecified": "bottomAlphabetical" }
    ],
    "media-feature-range-notation": "prefix",
    "media-feature-name-no-unknown": true,
    "media-feature-name-no-vendor-prefix": true,

    "declaration-property-value-disallowed-list": [
      {
        "/.+/": [
          "/#3b82f6/i",
          "/#2563eb/i",
          "/#007aff/i",
          "/#646cff/i",
          "/#4ab6f5/i",
          "/#1f36b9/i",
          "/#93c5fd/i",
          "/#2264f3/i",
          "/#2564eb/i",
          "/rgb\\(\\s*19,\\s*17,\\s*146/",
          "/rgb\\(\\s*14,\\s*13,\\s*110/",
          "/rgba\\(\\s*99,\\s*179,\\s*237/",
          "/rgba\\(\\s*0,\\s*122,\\s*255/"
        ]
      },
      {
        "message": "Retired legacy blue — use a brand token: var(--bg-surface-brand) / var(--primitive-brand-rose-terracotta|deep-umber|muted-clay). See docs/DESIGN_SYSTEM.md.",
        "severity": "error"
      }
    ]
  }
}
